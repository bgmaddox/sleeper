# Copy to .env at the project root and fill in real values (.env is gitignored).
# SECRET_KEY: signing key for auth cookies — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# LEAGUE_PASSWORD: the password league members type at /login
LEAGUE_PASSWORD=
# Optional: set to 1 to enable the Dash debug toolbar locally
# DASH_DEBUG=0
